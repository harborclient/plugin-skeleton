{
  "name": "@harborclient/plugin-skeleton",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm build:main && node scripts/build.mjs",
    "build:main": "esbuild src/main.ts --bundle --outfile=dist/main.js --format=esm --platform=neutral",
    "build:renderer": "node scripts/build.mjs",
    "dev": "pnpm dev:main & node scripts/build.mjs --watch",
    "dev:main": "esbuild src/main.ts --bundle --outfile=dist/main.js --format=esm --platform=neutral --watch",
    "dev:renderer": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "screenshot": "bash scripts/render-screenshot.sh",
    "pack": "pnpm build && zip -r skeleton.hcp manifest.json README.md dist",
    "plugin:sign": "node --experimental-strip-types scripts/plugin-sign.ts",
    "plugin:verify": "node --experimental-strip-types scripts/plugin-verify.ts"
  },
  "dependencies": {
    "@harborclient/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  }
}
